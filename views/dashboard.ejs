                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalEditUser" class="hidden fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-md flex items-center justify-center p-4">
    <div class="bg-white p-8 rounded-[48px] w-full max-w-lg shadow-2xl overflow-y-auto max-h-[90vh]">
        <h2 class="text-2xl font-black mb-6 uppercase tracking-tighter">Edit Data User</h2>
        <form action="/edit-user" method="POST" class="space-y-4">
            <input type="hidden" name="oldUsername" id="editOldUsername">
            
            <div class="grid grid-cols-2 gap-4">
                <input type="text" name="name" id="editName" placeholder="Nama Lengkap" class="p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-blue-500 font-bold" required>
                <input type="text" name="username" id="editUsername" placeholder="Username" class="p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-blue-500 font-bold" required>
            </div>
            <input type="email" name="email" id="editEmail" placeholder="Email Address" class="w-full p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-blue-500 font-bold" required>
            <input type="password" name="password" id="editPassword" placeholder="Password Baru (Kosongkan jika tidak ganti)" class="w-full p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-blue-500 font-bold">
            
            <select name="role" id="editRoleSelector" onchange="handleEditRoleChange()" class="w-full p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-blue-500 font-bold" required>
                <option value="Mitra">Mitra</option>
                <option value="Teknisi">Teknisi</option>
                <option value="Engineer">Engineer</option>
                <option value="Lead">Lead</option>
                <option value="Head">Head</option>
                <option value="SuperAdmin">SuperAdmin</option>
            </select>

            <div id="editMitraFields" class="hidden pt-4 border-t border-slate-100">
                <label class="text-[10px] font-black text-slate-400 uppercase ml-2 mb-2 block tracking-widest">Perusahaan Mitra</label>
                <select name="mitraName" id="editMitraName" class="w-full p-4 bg-blue-50 text-blue-700 rounded-2xl border-none font-bold">
                    <option value="">Pilih Nama Perusahaan Mitra</option>
                    <option value="ANUGERAH TEKNIK">ANUGERAH TEKNIK</option>
                    <option value="ARIF BERSAUDARA">ARIF BERSAUDARA</option>
                    <option value="BELLAVEGA">BELLAVEGA</option>
                    <option value="BORNEO SARANA TEKNIK">BORNEO SARANA TEKNIK</option>
                    <option value="CITRAMAS PRIMA">CITRAMAS PRIMA</option>
                    <option value="DIRGANTARA ERA MANDIRI">DIRGANTARA ERA MANDIRI</option>
                    <option value="INDONESIA NETWORK MEDIA">INDONESIA NETWORK MEDIA</option>
                    <option value="KOPKARLA">KOPKARLA</option>
                    <option value="SEWOLIDI MAKMUR SEJAHTERA">SEWOLIDI MAKMUR SEJAHTERA</option>
                    <option value="SINAR TIMUR MANDIRI">SINAR TIMUR MANDIRI</option>
                    <option value="SURYA MITRA SARANA">SURYA MITRA SARANA</option>
                </select>
            </div>

            <div id="editLocationFields" class="hidden space-y-4 pt-4 border-t border-slate-100">
                <label class="text-[10px] font-black text-slate-400 uppercase ml-2 mb-2 block tracking-widest text-center">Update Wilayah Tugas</label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-emerald-50/50 rounded-3xl border border-emerald-100">
                        <p class="text-[10px] font-black text-emerald-600 uppercase mb-3">Area EKO</p>
                        <% ['TANJUNG SELOR', 'BALIKPAPAN', 'SAMARINDA', 'BANJARMASIN'].forEach(cluster => { %>
                            <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                <input type="checkbox" name="clusters" value="EKO|<%= cluster %>" class="edit-cluster-cb w-4 h-4 rounded text-emerald-600">
                                <span class="text-xs font-bold text-slate-600"><%= cluster %></span>
                            </label>
                        <% }) %>
                    </div>
                    <div class="p-4 bg-indigo-50/50 rounded-3xl border border-indigo-100">
                        <p class="text-[10px] font-black text-indigo-600 uppercase mb-3">Area WKO</p>
                        <% ['PONTIANAK', 'PALANGKARAYA'].forEach(cluster => { %>
                            <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                <input type="checkbox" name="clusters" value="WKO|<%= cluster %>" class="edit-cluster-cb w-4 h-4 rounded text-indigo-600">
                                <span class="text-xs font-bold text-slate-600"><%= cluster %></span>
                            </label>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="flex gap-2 pt-4">
                <button type="submit" class="flex-1 bg-blue-600 text-white py-4 rounded-2xl font-bold shadow-lg">Update User</button>
                <button type="button" onclick="toggleModal('modalEditUser')" class="px-6 bg-slate-100 text-slate-500 py-4 rounded-2xl font-bold">Batal</button>
            </div>
        </form>
    </div>
</div>
<% } %>


<script>
    lucide.createIcons();
    const userRole = "<%= user.role %>";

    function formatRupiah(amount) {
        return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(amount);
    }

    function formatWaktu(isoString) {
        if (!isoString) return '';
        const date = new Date(isoString);
        return date.toLocaleString('id-ID', { 
            day: '2-digit', month: 'short', year: 'numeric', 
            hour: '2-digit', minute: '2-digit' 
        }).replace(',', ' -');
    }

    function toggleModal(id) { 
        const el = document.getElementById(id);
        el.classList.toggle('hidden');
        document.body.style.overflow = el.classList.contains('hidden') ? 'auto' : 'hidden';
    }

    function handleFileSelect(input, displayId) {
        const display = document.getElementById(displayId);
        if (input.files && input.files[0]) {
            display.innerText = "✓ " + input.files[0].name.toUpperCase();
            display.className = "text-[10px] font-black text-blue-600 uppercase";
        }
    }

function openDetail(item) {
    const userRole = '<%= user.role %>';
    
    // 1. Set Basic Info
    document.getElementById('modalId').innerText = `#${item.id.toString().slice(-6)}`;
    document.getElementById('pdfFrame').src = item.pdfPath;
    
    // 2. Set Meta Data Grid
    const metaContainer = document.getElementById('modalMeta');
    metaContainer.innerHTML = `
        <div class="p-3 bg-slate-50 rounded-2xl">
            <p class="text-[9px] text-slate-400 uppercase mb-1">Project</p>
            <p class="text-xs font-black text-slate-800">${item.projectName}</p>
        </div>
        <div class="p-3 bg-slate-50 rounded-2xl">
            <p class="text-[9px] text-slate-400 uppercase mb-1">Mitra</p>
            <p class="text-xs font-black text-blue-700">${item.mitraName || '-'}</p>
        </div>
        <div class="p-3 bg-slate-50 rounded-2xl">
            <p class="text-[9px] text-slate-400 uppercase mb-1">Area / Cluster</p>
            <p class="text-xs font-black text-slate-800">${item.area} / ${item.cluster}</p>
        </div>
        <div class="p-3 bg-slate-50 rounded-2xl">
            <p class="text-[9px] text-slate-400 uppercase mb-1">Jenis / Nilai</p>
            <p class="text-xs font-black text-slate-800">${item.jenisBalap} | Rp ${Number(item.nilai).toLocaleString('id-ID')}</p>
        </div>
    `;

    // 3. Render History
    const historyList = document.getElementById('historyList');
    historyList.innerHTML = item.comments.map(c => `
        <div class="p-3 rounded-2xl border ${c.type === 'REJECT' ? 'bg-red-50 border-red-100' : 'bg-slate-50 border-slate-100'}">
            <div class="flex justify-between mb-1">
                <span class="text-[10px] font-black text-slate-700">${c.user} (${c.role})</span>
                <span class="text-[9px] text-slate-400">${new Date(c.date).toLocaleString('id-ID')}</span>
            </div>
            <p class="text-xs text-slate-600 font-medium">${c.comment}</p>
        </div>
    `).join('') || '<p class="text-xs text-slate-400 italic">Belum ada catatan.</p>';

    // 4. Logic Tampilan Action Area (DIPERBAIKI UNTUK APPROVAL BERJENJANG)
    const actionArea = document.getElementById('actionArea');
    const mitraReuploadArea = document.getElementById('mitraReuploadArea');
    const leadOption = document.getElementById('leadOption');
    const approvalForm = document.getElementById('approvalForm');
    const reuploadForm = document.getElementById('reuploadForm');

    // Sembunyikan semua dulu
    actionArea.classList.add('hidden');
    mitraReuploadArea.classList.add('hidden');
    leadOption.classList.add('hidden');

    // Cek apakah sekarang giliran role tersebut
    const isGilirannya = 
        (userRole === 'Teknisi' && item.status === 'WAITING_TEKNISI') ||
        (userRole === 'Engineer' && item.status === 'WAITING_ENGINEER') ||
        (userRole === 'Lead' && item.status === 'WAITING_LEAD') ||
        (userRole === 'Head' && item.status === 'WAITING_HEAD');

    if (item.status === 'REJECTED' && userRole === 'Mitra') {
        mitraReuploadArea.classList.remove('hidden');
        reuploadForm.action = `/reupload/${item.id}`;
    } else if (isGilirannya) { // HANYA TAMPIL JIKA SESUAI URUTAN ROLE
        actionArea.classList.remove('hidden');
        approvalForm.action = `/approve/${item.id}`;
        
        // Munculkan opsi Lanjut Head hanya jika login sebagai Lead
        if (userRole === 'Lead') {
            leadOption.classList.remove('hidden');
        }
        
        // Setup tombol Reject
        document.getElementById('rejectBtn').onclick = () => {
            const comment = document.getElementById('actionTextarea').value;
            if(!comment) return Swal.fire('Oops!', 'Berikan alasan penolakan di kolom catatan.', 'warning');
            
            Swal.fire({
                title: 'Konfirmasi Reject',
                text: "Yakin ingin menolak pengajuan ini?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Ya, Reject'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = `/reject/${item.id}`;
                    const input = document.createElement('input');
                    input.name = 'comment';
                    input.value = comment;
                    form.appendChild(input);
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        };

        // Setup tombol Approve
        document.getElementById('approveBtn').onclick = () => {
            approvalForm.submit();
        };
    }

    toggleModal('modalProcess');
    setTimeout(() => lucide.createIcons(), 10);
}

function searchTable() {
        const val = document.getElementById("searchInput").value.toUpperCase();
        document.querySelectorAll('.row-data').forEach(row => {
            row.style.display = row.innerText.toUpperCase().includes(val) ? '' : 'none';
        });
    }

    function filterStatus(status) {
        document.querySelectorAll('.row-data').forEach(row => {
            const s = row.dataset.status;
            if(status === 'ALL') row.style.display = '';
            else if(status === 'PENDING') row.style.display = (s !== 'COMPLETED' && s !== 'REJECTED') ? '' : 'none';
            else row.style.display = s === status ? '' : 'none';
        });
    }

// Toggle Visibility Password
function togglePass(id) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
}

// Submit Ganti Password
async function submitChangePassword() {
    const oldPassword = document.getElementById('oldPass').value;
    const newPassword = document.getElementById('newPass').value;

    if(!oldPassword || !newPassword) return Swal.fire('Oops!', 'Semua kolom wajib diisi.', 'warning');

    const res = await fetch('/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ oldPassword, newPassword })
    });

    const result = await res.json();
    if(result.success) {
        Swal.fire({ icon: 'success', title: 'Berhasil!', text: result.message }).then(() => location.reload());
    } else {
        Swal.fire('Gagal!', result.message, 'error');
    }
}

// Konfirmasi Hapus User (SuperAdmin)
function confirmDeleteUser(username) {
    Swal.fire({
        title: 'Hapus User?',
        text: `Konfirmasi penghapusan user @${username}. Tindakan ini tidak bisa dibatalkan!`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        confirmButtonText: 'Ya, Hapus!'
    }).then(async (result) => {
        if (result.isConfirmed) {
            const res = await fetch(`/delete-user/${username}`, { method: 'POST' });
            const data = await res.json();
            if(data.success) {
                Swal.fire('Terhapus!', data.message, 'success').then(() => location.reload());
            }
        }
    });
}

// 1. Fungsi Toggle Password Visibility
function togglePass(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.innerHTML = lucide.icons['eye-off'].toSvg(); // Ganti icon manual
    } else {
        input.type = 'password';
        icon.innerHTML = lucide.icons['eye'].toSvg();
    }
}

// 2. Fungsi Edit User yang Lengkap
function openEditUser(userDataStr) {
    // Parsing data string kembali ke objek
    const u = JSON.parse(userDataStr);
    
    document.getElementById('editOldUsername').value = u.username;
    document.getElementById('editUsername').value = u.username;
    document.getElementById('editName').value = u.name;
    document.getElementById('editEmail').value = u.email || '';
    document.getElementById('editRoleSelector').value = u.role;
    document.getElementById('editMitraName').value = u.mitraName || '';

    // Reset semua checkbox cluster
    document.querySelectorAll('.edit-cluster-cb').forEach(cb => cb.checked = false);
    
    // Centang checkbox yang sesuai dengan data user
    if (u.clusters && Array.isArray(u.clusters)) {
        u.clusters.forEach(c => {
            const cb = document.querySelector(`.edit-cluster-cb[value="${c}"]`);
            if (cb) cb.checked = true;
        });
    }

    handleEditRoleChange();
    toggleModal('modalEditUser');
}

function handleEditRoleChange() {
    const role = document.getElementById('editRoleSelector').value;
    const mitraFields = document.getElementById('editMitraFields');
    const locFields = document.getElementById('editLocationFields');

    mitraFields.classList.toggle('hidden', role !== 'Mitra');
    locFields.classList.toggle('hidden', role === 'SuperAdmin'); 
}
// 3. Submit Ganti Password (FIX)
async function submitChangePassword() {
    const oldPassword = document.getElementById('oldPass').value;
    const newPassword = document.getElementById('newPass').value;

    const res = await fetch('/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ oldPassword, newPassword })
    });

    const result = await res.json();
    if(result.success) {
        Swal.fire('Berhasil!', result.message, 'success').then(() => location.reload());
    } else {
        Swal.fire('Gagal!', result.message, 'error');
    }
}


function handleRoleChange() {
    const role = document.getElementById('roleSelector').value;
    const mitraFields = document.getElementById('mitraFields');
    const locationFields = document.getElementById('locationFields');

    // Reset hidden states
    mitraFields.classList.add('hidden');
    locationFields.classList.add('hidden');

    if (role === 'Mitra') {
        mitraFields.classList.remove('hidden');
        locationFields.classList.remove('hidden');
    } else if (['Teknisi', 'Engineer', 'Lead', 'Head'].includes(role)) {
        // Role internal hanya butuh Area & Cluster, tidak butuh Nama Perusahaan Mitra
        locationFields.classList.remove('hidden');
    }
}

// Fungsi validasi ukuran file & ganti label nama file
function validateAndPreview(input, labelId) {
    const file = input.files[0];
    const label = document.getElementById(labelId);

    if (file) {
        // Cek Ukuran (5MB = 5 * 1024 * 1024 bytes)
        if (file.size > 5 * 1024 * 1024) {
            Swal.fire({
                icon: 'error',
                title: 'File Terlalu Besar',
                text: 'Ukuran file maksimal adalah 5MB. Silakan kompres PDF Anda.',
                confirmButtonColor: '#3b82f6'
            });
            input.value = ''; // Reset input
            label.innerText = 'Tarik file PDF ke sini atau klik';
            return;
        }

        // Cek Tipe File
        if (file.type !== 'application/pdf') {
            Swal.fire('Error', 'Hanya file format PDF yang diperbolehkan!', 'error');
            input.value = '';
            return;
        }

        label.innerText = file.name;
    }
}

// Fungsi validasi simpel untuk input file opsional di modalProcess
function validateFileSize(input) {
    if (input.files[0] && input.files[0].size > 5 * 1024 * 1024) {
        Swal.fire('File Terlalu Besar', 'Maksimal ukuran file adalah 5MB.', 'warning');
        input.value = '';
    }
}

let idleTimer;
    // Waktu tunggu harus sama dengan maxAge di server (30 menit)
    const timeoutDuration = 15 * 60 * 1000; 

    function resetTimer() {
        clearTimeout(idleTimer);
        idleTimer = setTimeout(logoutUser, timeoutDuration);
    }

    function logoutUser() {
        // Menggunakan SweetAlert2 yang sudah ada di dashboard Anda
        Swal.fire({
            title: 'Sesi Berakhir',
            text: 'Demi keamanan, Anda telah dikeluarkan otomatis karena tidak ada aktivitas selama 30 menit.',
            icon: 'warning',
            confirmButtonColor: '#3b82f6',
            confirmButtonText: 'Login Kembali'
        }).then(() => {
            window.location.href = '/logout';
        });
    }

    // Pantau aktivitas user (gerak mouse, ketik, scroll)
    const events = ['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart'];
    events.forEach(name => {
        document.addEventListener(name, resetTimer, true);
    });

    // Mulai hitung mundur saat halaman dimuat
    resetTimer();

function addSubmissionRow() {
    const container = document.getElementById('bulkContainer');
    const firstItem = document.querySelector('.submission-item');
    const newItem = firstItem.cloneNode(true);
    
    // Reset semua nilai input
    newItem.querySelectorAll('input:not([readonly])').forEach(input => input.value = '');
    newItem.querySelectorAll('select').forEach(select => select.selectedIndex = 0);
    
    // Reset teks upload
    const label = newItem.querySelector('.file-display-name');
    if(label) label.innerText = "Tarik file PDF ke sini atau klik";
    
    // Tambahkan tombol hapus jika belum ada
    if (!newItem.querySelector('.remove-row-btn')) {
        const removeBtn = document.createElement('button');
        removeBtn.type = "button";
        removeBtn.className = "remove-row-btn absolute -top-2 -right-2 bg-red-500 text-white p-1.5 rounded-full shadow-lg hover:bg-red-600 z-30";
        removeBtn.innerHTML = '<i data-lucide="x" class="w-4 h-4"></i>';
        removeBtn.onclick = function() { this.closest('.submission-item').remove(); };
        newItem.appendChild(removeBtn);
    }

    container.appendChild(newItem);
    if (typeof lucide !== 'undefined') lucide.createIcons();
}

// Fungsi validasi yang kompatibel dengan baris dinamis
function validateAndPreview(input, labelElement) {
    const file = input.files[0];
    if (file) {
        if (file.size > 5 * 1024 * 1024) {
            Swal.fire('File Terlalu Besar', 'Maksimal 5MB.', 'warning');
            input.value = '';
            labelElement.innerText = "Tarik file PDF ke sini atau klik";
            return;
        }
        labelElement.innerText = file.name;
        labelElement.classList.add('text-blue-600');
    }
}

</script>

</body>
</html>