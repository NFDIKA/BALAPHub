<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BALAPHub | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
        .upload-area.drag-over { border-color: #3b82f6; background-color: #eff6ff; transform: scale(1.01); }
        .upload-area { transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-[#F1F5F9] text-slate-900">

    <nav class="sticky top-0 z-50 border-b border-white bg-white/70 backdrop-blur-xl px-4 md:px-8 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 p-2.5 rounded-2xl text-white shadow-lg shadow-blue-200">
                <i data-lucide="component" class="w-6 h-6"></i>
            </div>
            <span class="text-2xl font-black italic tracking-tighter uppercase">BALAP<span class="text-blue-600">Hub</span></span>
        </div>
        <div class="flex items-center gap-4">
            <div class="hidden md:block text-right">
                <p class="text-[9px] font-black text-blue-600 uppercase tracking-widest leading-none mb-1"><%= user.role %></p>
                <p class="text-sm font-bold text-slate-700"><%= user.name %></p>
            </div>
            <a href="/logout" class="bg-red-50 text-red-500 p-3 rounded-2xl hover:bg-red-500 hover:text-white transition-all duration-300">
                <i data-lucide="power" class="w-5 h-5"></i>
            </a>
            <% if (user.role === 'SuperAdmin') { %>
                <button onclick="toggleModal('modalUserManagement')" class="bg-purple-50 text-purple-600 p-3 rounded-2xl hover:bg-purple-600 hover:text-white transition-all shadow-sm">
                    <i data-lucide="users" class="w-5 h-5"></i>
                </button>
            <% } %>
            <button onclick="toggleModal('modalPassword')" class="bg-blue-50 text-blue-500 p-3 rounded-2xl hover:bg-blue-600 hover:text-white transition-all">
                <i data-lucide="key" class="w-5 h-5"></i>
            </button>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-4 md:p-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight mb-2">Pusat Kendali Dokumen</h1>
                <p class="text-slate-500 font-medium">Lacak progress pengajuan BALAP Anda secara transparan.</p>
            </div>
            <% if(user.role === 'Mitra') { %>
                <button onclick="toggleModal('modalTambah')" class="bg-blue-600 text-white px-8 py-4 rounded-3xl font-bold shadow-2xl shadow-blue-200 hover:bg-blue-700 transition-all flex items-center justify-center gap-3 active:scale-95">
                    <i data-lucide="plus" class="w-6 h-6"></i> Buat Pengajuan Baru
                </button>
            <% } %>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <button onclick="filterStatus('ALL')" class="status-card bg-white p-6 rounded-[32px] border border-slate-200 shadow-sm text-left hover:border-blue-500 transition-all">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">Semua</p>
                <h3 class="text-3xl font-black text-slate-800"><%= data.length %></h3>
            </button>
            <button onclick="filterStatus('PENDING')" class="status-card bg-white p-6 rounded-[32px] border border-slate-200 shadow-sm text-left hover:border-amber-500 transition-all border-b-4 border-b-amber-400">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">Pending</p>
                <h3 class="text-3xl font-black text-amber-500"><%= data.filter(d => d.status !== 'COMPLETED' && d.status !== 'REJECTED').length %></h3>
            </button>
            <button onclick="filterStatus('COMPLETED')" class="status-card bg-white p-6 rounded-[32px] border border-slate-200 shadow-sm text-left hover:border-emerald-500 transition-all border-b-4 border-b-emerald-400">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">Selesai</p>
                <h3 class="text-3xl font-black text-emerald-500"><%= data.filter(d => d.status === 'COMPLETED').length %></h3>
            </button>
            <button onclick="filterStatus('REJECTED')" class="status-card bg-white p-6 rounded-[32px] border border-slate-200 shadow-sm text-left hover:border-red-500 transition-all border-b-4 border-b-red-400">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">Ditolak</p>
                <h3 class="text-3xl font-black text-red-500"><%= data.filter(d => d.status === 'REJECTED').length %></h3>
            </button>
        </div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-10">
    
    <% if (user.role !== 'Mitra') { %>
        <div class="bg-white p-7 rounded-[40px] border border-slate-100 shadow-sm flex flex-col">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-amber-50 rounded-xl text-amber-500"><i data-lucide="award" class="w-5 h-5"></i></div>
                <h3 class="text-[11px] font-black uppercase tracking-widest text-slate-800 italic">Peringkat Mitra</h3>
            </div>
            <div class="space-y-4 overflow-y-auto custom-scrollbar pr-1">
                <% rankingMitra.slice(0, 5).forEach((m, i) => { %>
                    <div class="p-4 bg-slate-50 rounded-3xl border border-transparent hover:border-amber-200 transition-all mb-1">
                        <div class="flex justify-between items-start mb-2">
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-black <%= i === 0 ? 'text-amber-500' : 'text-slate-300' %>">#<%= i+1 %></span>
                                <p class="text-[10px] font-black text-slate-800 uppercase tracking-tight"><%= m.name %></p>
                            </div>
                            <span class="text-[10px] font-black text-blue-600">Rp <%= m.totalNilai.toLocaleString('id-ID') %></span>
                        </div>
                        
                        <div class="grid grid-cols-3 gap-1 mb-2 border-b border-slate-200 pb-2">
                            <div class="text-[7px] font-bold text-blue-500 text-center uppercase">PSB: Rp <%= m.nilaiPsb.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-orange-500 text-center uppercase">CM: Rp <%= m.nilaiCm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-purple-500 text-center uppercase">PM: Rp <%= m.nilaiPm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-green-500 text-center uppercase">Mutasi: Rp <%= m.nilaiMutasi.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-red-500 text-center uppercase">Dismantle: Rp <%= m.nilaiDismantle.toLocaleString('id-ID') %></div>
                            
                        </div>

                        <div class="grid grid-cols-4 gap-1 text-center">
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Total</p><p class="text-[9px] font-black text-slate-700"><%= m.count %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PSB</p><p class="text-[9px] font-black text-blue-500"><%= m.psb %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">CM</p><p class="text-[9px] font-black text-orange-500"><%= m.cm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PM</p><p class="text-[9px] font-black text-purple-500"><%= m.pm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Mutasi</p><p class="text-[9px] font-black text-green-500"><%= m.mutasi %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Dismantle</p><p class="text-[9px] font-black text-red-500"><%= m.dismantle %></p></div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="bg-white p-7 rounded-[40px] border border-slate-100 shadow-sm flex flex-col">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-blue-50 rounded-xl text-blue-500"><i data-lucide="map-pin" class="w-5 h-5"></i></div>
                <h3 class="text-[11px] font-black uppercase tracking-widest text-slate-800 italic">Top Cluster</h3>
            </div>
            <div class="space-y-4 overflow-y-auto custom-scrollbar pr-1">
                <% rankingCluster.slice(0, 5).forEach((c, i) => { %>
                    <div class="p-4 bg-slate-50 rounded-3xl border border-transparent hover:border-blue-200 transition-all mb-1">
                        <div class="flex justify-between items-start mb-2">
                            <p class="text-[10px] font-black text-slate-800 uppercase tracking-tight text-left"><%= c.name %></p>
                            <span class="text-[10px] font-black text-blue-600">Rp <%= c.totalNilai.toLocaleString('id-ID') %></span>
                        </div>

                        <div class="grid grid-cols-3 gap-1 mb-2 border-b border-slate-200 pb-2">
                            <div class="text-[7px] font-bold text-blue-500 text-center uppercase">PSB: Rp <%= c.nilaiPsb.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-orange-500 text-center uppercase">CM: Rp <%= c.nilaiCm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-purple-500 text-center uppercase">PM: Rp <%= c.nilaiPm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-green-500 text-center uppercase">Mutasi: Rp <%= c.nilaiMutasi.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-red-500 text-center uppercase">Dismantle: Rp <%= c.nilaiDismantle.toLocaleString('id-ID') %></div>
                        </div>

                        <div class="grid grid-cols-4 gap-1 text-center">
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Total</p><p class="text-[9px] font-black text-slate-700"><%= c.count %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PSB</p><p class="text-[9px] font-black text-blue-500"><%= c.psb %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">CM</p><p class="text-[9px] font-black text-orange-500"><%= c.cm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PM</p><p class="text-[9px] font-black text-purple-500"><%= c.pm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Mutasi</p><p class="text-[9px] font-black text-green-500"><%= c.mutasi %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Dismantle</p><p class="text-[9px] font-black text-red-500"><%= c.dismantle %></p></div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="bg-white p-7 rounded-[40px] border border-slate-100 shadow-sm flex flex-col">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-emerald-50 rounded-xl text-emerald-500"><i data-lucide="pie-chart" class="w-5 h-5"></i></div>
                <h3 class="text-[11px] font-black uppercase tracking-widest text-slate-800 italic">Kontribusi Area</h3>
            </div>
            <div class="space-y-4 overflow-y-auto custom-scrollbar pr-1">
                <% rankingArea.forEach(a => { %>
                    <div class="p-4 bg-slate-50 rounded-3xl border border-slate-100 mb-4 transition-all hover:border-emerald-200">
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-[10px] font-black text-slate-800 uppercase tracking-tight"><%= a.name %></span>
                            <span class="text-[10px] font-black text-emerald-600">Rp <%= a.totalNilai.toLocaleString('id-ID') %></span>
                        </div>
                        
                        <div class="grid grid-cols-3 gap-1 mb-2 border-b border-slate-200 pb-2">
                            <div class="text-[7px] font-bold text-blue-500 text-center uppercase">PSB: Rp <%= a.nilaiPsb.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-orange-500 text-center uppercase">CM: Rp <%= a.nilaiCm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-purple-500 text-center uppercase">PM: Rp <%= a.nilaiPm.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-green-500 text-center uppercase">Mutasi: Rp <%= a.nilaiMutasi.toLocaleString('id-ID') %></div>
                            <div class="text-[7px] font-bold text-red-500 text-center uppercase">Dismantle: Rp <%= a.nilaiDismantle.toLocaleString('id-ID') %></div>

                        </div>

                        <div class="grid grid-cols-4 gap-1 text-center">
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Total</p><p class="text-[9px] font-black text-slate-700"><%= a.count %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PSB</p><p class="text-[9px] font-black text-blue-500"><%= a.psb %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">CM</p><p class="text-[9px] font-black text-orange-500"><%= a.cm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">PM</p><p class="text-[9px] font-black text-purple-500"><%= a.pm %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Mutasi</p><p class="text-[9px] font-black text-green-500"><%= a.mutasi %></p></div>
                            <div><p class="text-[7px] font-bold text-slate-400 uppercase">Dismantle</p><p class="text-[9px] font-black text-red-500"><%= a.dismantle %></p></div>
                        </div>
                    </div>
                <% }) %>

                <div class="p-4 bg-blue-600 rounded-3xl shadow-xl shadow-blue-100 mt-2">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-[10px] font-black text-white uppercase tracking-tight italic">KAA (TOTAL GABUNGAN)</span>
                        <span class="text-[10px] font-black text-blue-100">Rp <%= totalKaa.totalNilai.toLocaleString('id-ID') %></span>
                    </div>

                    <div class="grid grid-cols-3 gap-1 mb-2 border-b border-blue-400/30 pb-2">
                        <div class="text-[7px] font-bold text-blue-100 text-center uppercase">PSB: Rp <%= totalKaa.nilaiPsb.toLocaleString('id-ID') %></div>
                        <div class="text-[7px] font-bold text-orange-100 text-center uppercase">CM: Rp <%= totalKaa.nilaiCm.toLocaleString('id-ID') %></div>
                        <div class="text-[7px] font-bold text-purple-100 text-center uppercase">PM: Rp <%= totalKaa.nilaiPm.toLocaleString('id-ID') %></div>
                        <div class="text-[7px] font-bold text-green-100 text-center uppercase">Mutasi: Rp <%= totalKaa.nilaiMutasi.toLocaleString('id-ID') %></div>
                        <div class="text-[7px] font-bold text-red-100 text-center uppercase">Dismantle: Rp <%= totalKaa.nilaiDismantle.toLocaleString('id-ID') %></div>
                    </div>

                    <div class="grid grid-cols-4 gap-1 text-center">
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">Total</p><p class="text-[9px] font-black text-white"><%= totalKaa.count %></p></div>
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">PSB</p><p class="text-[9px] font-black text-white"><%= totalKaa.psb %></p></div>
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">CM</p><p class="text-[9px] font-black text-white"><%= totalKaa.cm %></p></div>
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">PM</p><p class="text-[9px] font-black text-white"><%= totalKaa.pm %></p></div>
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">Mutasi</p><p class="text-[9px] font-black text-white"><%= totalKaa.mutasi %></p></div>
                        <div><p class="text-[7px] font-bold text-blue-200 uppercase">Dismantle</p><p class="text-[9px] font-black text-white"><%= totalKaa.dismantle %></p></div>
                    </div>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="xl:col-span-3 bg-white p-8 rounded-[40px] border border-slate-100 shadow-sm">
            <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                <div class="flex items-center gap-6">
                    <div class="w-16 h-16 bg-blue-50 rounded-3xl flex items-center justify-center text-blue-600 shadow-inner">
                        <i data-lucide="briefcase" class="w-8 h-8"></i>
                    </div>
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Performa Perusahaan</p>
                        <h3 class="text-xl font-black text-slate-800 uppercase italic"><%= mitraSelfStats.name %></h3>
                    </div>
                </div>
                
                <div class="flex flex-wrap gap-4 justify-center md:justify-end">
                    <div class="text-center p-4 bg-blue-50 rounded-2xl min-w-[140px] border border-blue-100">
                        <p class="text-[8px] font-black text-blue-400 uppercase mb-1">TOTAL PSB</p>
                        <p class="text-sm font-black text-blue-600">Rp <%= mitraSelfStats.nilaiPsb.toLocaleString('id-ID') %></p>
                        <p class="text-[9px] font-bold text-blue-300 mt-1 uppercase"><%= mitraSelfStats.psb %> UNIT</p>
                    </div>
                    <div class="text-center p-4 bg-orange-50 rounded-2xl min-w-[140px] border border-orange-100">
                        <p class="text-[8px] font-black text-orange-400 uppercase mb-1">TOTAL CM</p>
                        <p class="text-sm font-black text-orange-600">Rp <%= mitraSelfStats.nilaiCm.toLocaleString('id-ID') %></p>
                        <p class="text-[9px] font-bold text-orange-300 mt-1 uppercase"><%= mitraSelfStats.cm %> UNIT</p>
                    </div>
                    <div class="text-center p-4 bg-purple-50 rounded-2xl min-w-[140px] border border-purple-100">
                        <p class="text-[8px] font-black text-purple-400 uppercase mb-1">TOTAL PM</p>
                        <p class="text-sm font-black text-purple-600">Rp <%= mitraSelfStats.nilaiPm.toLocaleString('id-ID') %></p>
                        <p class="text-[9px] font-bold text-purple-300 mt-1 uppercase"><%= mitraSelfStats.pm %> UNIT</p>
                    </div>
                    <div class="text-center p-4 bg-green-50 rounded-2xl min-w-[140px] border border-green-100">
                        <p class="text-[8px] font-black text-green-400 uppercase mb-1">TOTAL MUTASI</p>
                        <p class="text-sm font-black text-green-600">Rp <%= mitraSelfStats.nilaiMutasi.toLocaleString('id-ID') %></p>
                        <p class="text-[9px] font-bold text-green-300 mt-1 uppercase"><%= mitraSelfStats.mutasi %> UNIT</p>
                    </div>
                    <div class="text-center p-4 bg-red-50 rounded-2xl min-w-[140px] border border-red-100">
                        <p class="text-[8px] font-black text-red-400 uppercase mb-1">TOTAL DISMANTLE</p>
                        <p class="text-sm font-black text-red-600">Rp <%= mitraSelfStats.nilaiDismantle.toLocaleString('id-ID') %></p>
                        <p class="text-[9px] font-bold text-red-300 mt-1 uppercase"><%= mitraSelfStats.dismantle %> UNIT</p>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

        <div class="bg-white rounded-[40px] border border-slate-200 shadow-xl overflow-hidden">
            <div class="p-6 md:p-8 flex flex-col md:flex-row justify-between items-center gap-4 border-b border-slate-50">
                <div class="flex items-center gap-2">
                    <i data-lucide="list-filter" class="w-5 h-5 text-blue-600"></i>
                    <h2 class="font-bold text-slate-700">Daftar Pengajuan Terbaru</h2>
                </div>
                <% if(user.role === 'SuperAdmin') { %>
                    <button onclick="toggleModal('modalUser')" class="bg-indigo-600 text-white px-8 py-4 rounded-3xl font-bold shadow-lg hover:bg-indigo-700 transition-all flex items-center gap-3">
                        <i data-lucide="user-plus"></i> Kelola User
                    </button>
                <% } %>
                <div class="relative w-full md:w-80">
                    <i data-lucide="search" class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Cari project, mitra, atau cluster..." class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-2xl text-sm outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                </div>
            </div>

            <div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left border-separate border-spacing-y-3" id="mainTable">
    <thead class="bg-slate-50/50 text-[10px] font-black text-slate-400 uppercase tracking-widest">
        <tr>
            <th class="p-6">Project & ID</th>
            <th class="p-6">Mitra & Wilayah</th>
            <th class="p-6">Nilai (Rp)</th>
            <th class="p-6">Progress Alur</th>
            <th class="p-6">Status Terakhir</th>
            <th class="p-6 text-center">Aksi</th>
        </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
        <% data.reverse().forEach(item => { %>
        <tr class="bg-white hover:bg-slate-50 transition-all shadow-sm rounded-3xl row-data" data-status="<%= item.status %>">
            <td class="p-6 first:rounded-l-[32px]">
                <div class="flex items-center gap-3">
                    <div class="p-3 bg-blue-50 text-blue-600 rounded-2xl">
                        <i data-lucide="briefcase" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <p class="font-extrabold text-slate-900 uppercase italic leading-none mb-1">#<%= item.id.toString().slice(-6) %></p>
                        <p class="text-[11px] text-slate-600 font-black uppercase tracking-tight line-clamp-1"><%= item.projectName %></p>
                    </div>
                </div>
            </td>

            <td class="p-6">
                <p class="text-xs font-black text-blue-700 italic uppercase mb-1">
                    <%= item.mitraName || 'INTERNAL' %>
                </p>
                <div class="flex flex-wrap gap-1">
                    <span class="text-[9px] bg-slate-100 px-2 py-0.5 rounded-full text-slate-500 font-bold uppercase"><%= item.area %></span>
                    <span class="text-[9px] bg-indigo-50 px-2 py-0.5 rounded-full text-indigo-600 font-bold uppercase"><%= item.cluster %></span>
                    <span class="text-[9px] bg-amber-50 px-2 py-0.5 rounded-full text-amber-600 font-bold uppercase"><%= item.jenisBalap %></span>
                </div>
            </td>

            <td class="p-6">
                <p class="text-sm font-black text-slate-800">
                    <%= new Intl.NumberFormat('id-ID').format(item.nilai) %>
                </p>
                <p class="text-[8px] text-slate-400 font-bold uppercase tracking-widest">IDR Currency</p>
            </td>

            <td class="p-6">
                <div class="flex gap-1.5 items-center mb-2">
                    <% 
                        // Logic for 5 Steps (Teknisi, Engineer, Lead, Head, Completed)
                        const maxSteps = item.status === 'WAITING_HEAD' || item.step > 3 ? 5 : 4;
                    %>
                    <% for(let i=1; i<=maxSteps; i++) { %>
                        <div class="h-2 w-6 rounded-full transition-all duration-500
                            <%= item.status === 'REJECTED' ? 'bg-red-100' : 
                               (item.step > i ? 'bg-emerald-500' : 
                               (item.step === i ? 'bg-blue-600 animate-pulse shadow-[0_0_8px_rgba(37,99,235,0.5)]' : 'bg-slate-200')) %>">
                        </div>
                    <% } %>
                </div>
                <div class="flex justify-between items-center w-full max-w-[140px]">
                    <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest">
                        Step <%= item.step %> of <%= maxSteps %>
                    </p>
                    <% if(item.status === 'COMPLETED') { %>
                        <i data-lucide="check-circle-2" class="w-3 h-3 text-emerald-500"></i>
                    <% } %>
                </div>
            </td>

            <td class="p-6">
                <div class="flex flex-col gap-1">
                    <span class="w-fit px-3 py-1 rounded-lg text-[9px] font-black border uppercase italic shadow-sm
                        <%= item.status === 'COMPLETED' ? 'bg-emerald-50 text-emerald-600 border-emerald-200' : 
                           (item.status === 'REJECTED' ? 'bg-red-50 text-red-600 border-red-200' : 
                           'bg-amber-50 text-amber-600 border-amber-200 animate-fade-in') %>">
                        <%= item.status.replace(/_/g, ' ') %>
                    </span>
                    <div class="flex items-center gap-1 text-[8px] text-slate-400 font-medium">
                        <i data-lucide="calendar" class="w-2.5 h-2.5"></i>
                        <%= new Date(item.lastUpdate).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %>
                    </div>
                </div>
            </td>

            <td class="p-6 text-center last:rounded-r-[32px]">
                <button 
                    data-item='<%- JSON.stringify(item).replace(/'/g, "&#39;").replace(/\r?\n|\r/g, " ") %>' 
                    onclick="openDetail(JSON.parse(this.dataset.item))" 
                    class="group bg-slate-900 text-white p-3 rounded-2xl hover:bg-blue-600 transition-all flex items-center justify-center mx-auto shadow-lg shadow-slate-200 hover:shadow-blue-200 active:scale-95"
                >
                    <i data-lucide="eye" class="w-4 h-4 group-hover:scale-110 transition-transform"></i>
                </button>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>
</div>
        </div>
    </main>

